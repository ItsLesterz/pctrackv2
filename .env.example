# Opcion A: PostgreSQL externo (Supabase, Neon, Render, Railway, etc.)
DATABASE_URL=postgresql://usuario:password@host:5432/base?sslmode=require

# Opcion B: Netlify Database
# Netlify puede resolver la conexion automaticamente con @netlify/database.
# Si usas una variable manual, tambien se aceptan estas:
# NETLIFY_DATABASE_URL=
# NETLIFY_DB_URL=

SESSION_SECRET=cambia_esto_por_un_texto_largo_y_privado
